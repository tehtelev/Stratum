+	private bool TryAcceptStratumMovementPacket(ServerPlayer player, Entity entity, Packet_EntityPosition packet, int serverPositionVersion, int currentTick, string stateKey)
+	{
+		if (player == null || entity == null || packet == null || string.IsNullOrEmpty(stateKey))
+		{
+			return false;
+		}
+
+		if (packet.PositionVersion > serverPositionVersion || player.WorldData.CurrentGameMode == EnumGameMode.Creative || entity.Controls.NoClip)
+		{
+			RememberStratumMovement(entity, stateKey);
+			return true;
+		}
+
+		double packetX = packet.X / 16384.0;
+		double packetY = packet.Y / 16384.0;
+		double packetZ = packet.Z / 16384.0;
+		long now = server.ElapsedMilliseconds;
+
+		if (!stratumMovementByPlayerUid.TryGetValue(stateKey, out StratumMovementState state))
+		{
+			stratumMovementByPlayerUid[stateKey] = new StratumMovementState
+			{
+				X = entity.Pos.X,
+				Y = entity.Pos.InternalY,
+				Z = entity.Pos.Z,
+				LastMs = now,
+				WindowStartMs = now
+			};
+			return true;
+		}
+
+		double elapsedSeconds = Math.Max(0.05, (now - state.LastMs) / 1000.0);
+		double dx = packetX - state.X;
+		double dy = packetY - state.Y;
+		double dz = packetZ - state.Z;
+		double horizontal = Math.Sqrt(dx * dx + dz * dz);
+		double total = Math.Sqrt(dx * dx + dy * dy + dz * dz);
+
+		if (now - state.WindowStartMs > 1000)
+		{
+			state.WindowStartMs = now;
+			state.WindowDistance = 0;
+		}
+		state.WindowDistance += total;
+
+		double maxHorizontal = StratumMaxHorizontalBlocksPerSecond * elapsedSeconds + StratumMovementSlackBlocks;
+		double maxVerticalUp = StratumMaxVerticalUpBlocksPerSecond * elapsedSeconds + StratumMovementSlackBlocks;
+		if (horizontal > maxHorizontal || dy > maxVerticalUp || state.WindowDistance > StratumMaxCumulativeBlocksPerSecond)
+		{
+			server.api.Logger.Audit("Rejected suspicious player movement for {0}. Delta={1:0.00}/{2:0.00}/{3:0.00}, window={4:0.00}", player.PlayerName, dx, dy, dz, state.WindowDistance);
+			SendSinglePositionPacket(player, entity, currentTick);
+			state.X = entity.Pos.X;
+			state.Y = entity.Pos.InternalY;
+			state.Z = entity.Pos.Z;
+			state.LastMs = now;
+			state.WindowStartMs = now;
+			state.WindowDistance = 0;
+			return false;
+		}
+
+		state.X = packetX;
+		state.Y = packetY;
+		state.Z = packetZ;
+		state.LastMs = now;
+		return true;
+	}
