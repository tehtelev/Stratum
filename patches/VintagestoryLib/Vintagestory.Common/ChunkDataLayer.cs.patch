+    [MethodImpl(MethodImplOptions.AggressiveInlining)]
+    private int RapidValueSearch(int intIndex, int needle)
+    {
+        int num = -1;
+        for (int i = 0; i < bitsize; i++)
+        {
+            num &= (((needle & (1 << i)) != 0) ? dataBits[i][intIndex] : (~dataBits[i][intIndex]));
