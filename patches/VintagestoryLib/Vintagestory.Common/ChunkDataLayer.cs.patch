+    private void CleanUnusedValuesFromEndOfPalette()
+    {
+        int num = paletteCount - 1;
+        for (int num2 = num / 32; num2 >= 0; num2--)
+        {
+            int num3 = paletteBitmap[num2];
+            if (num3 == 0)
+            {
+                paletteCount -= 32;
+            }
+            else
+            {
+                int num4 = 31;
+                if (num2 == num / 32 && num % 32 < num4)
+                {
+                    num4 = num % 32;
+                }
+                while (num4 >= 0)
+                {
+                    if ((num3 & (1 << num4)) != 0)
+                    {
+                        return;
+                    }
+                    paletteCount--;
+                    num4--;
+                }
+            }
+        }
+    }
