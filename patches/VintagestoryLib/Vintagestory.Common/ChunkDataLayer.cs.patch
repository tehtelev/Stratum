+    private int CalcBitsize(int paletteCount)
+    {
+        if (paletteCount == 0)
+        {
+            return 0;
+        }
+        int num = paletteCount - 1;
+        int num2 = 1;
+        while ((num >>= 1) > 0)
+        {
+            num2++;
+        }
+        return num2;
+    }
