+	private void FindNearestRayIntersectingEntity(Ray ray, float range, EntityFilter efilter, ref Entity selectedEntity, ref double nearestDistance)
+	{
+		int chunkX1 = (int)((ray.origin.X - range) / 32.0);
+		int chunkX2 = (int)((ray.origin.X + range) / 32.0);
+		int chunkY1 = (int)((ray.origin.Y - range) / 32.0);
+		int chunkY2 = (int)((ray.origin.Y + range) / 32.0);
+		int chunkZ1 = (int)((ray.origin.Z - range) / 32.0);
+		int chunkZ2 = (int)((ray.origin.Z + range) / 32.0);
+		float rangeSq = range * range;
+		for (int chunkX = chunkX1; chunkX <= chunkX2; chunkX++)
+		{
+			for (int chunkY = chunkY1; chunkY <= chunkY2; chunkY++)
+			{
+				for (int chunkZ = chunkZ1; chunkZ <= chunkZ2; chunkZ++)
+				{
+					IWorldChunk chunk = World.BlockAccessor.GetChunk(chunkX, chunkY, chunkZ);
+					Entity[] entities = chunk?.Entities;
+					if (entities == null)
+					{
+						continue;
+					}
+
+					for (int i = 0; i < entities.Length; i++)
+					{
+						Entity entity = entities[i];
