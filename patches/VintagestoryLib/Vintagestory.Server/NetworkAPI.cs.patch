+	// Stratum: expose custom packet channel names for packet attribution reports.
+	internal bool StratumTryGetChannelName(int channelId, bool udp, out string channelName)
+	{
+		if (udp)
+		{
+			if (channelsUdp.TryGetValue(channelId, out UdpNetworkChannel udpChannel))
+			{
+				channelName = udpChannel.ChannelName;
+				return true;
+			}
+		}
+		else if (channels.TryGetValue(channelId, out NetworkChannel channel))
+		{
+			channelName = channel.ChannelName;
+			return true;
+		}
+
+		channelName = null;
+		return false;
+	}
+
 	public IServerNetworkChannel RegisterChannel(string channelName)
 	{
 		nextFreeChannelId++;
 		channels[nextFreeChannelId] = new NetworkChannel(this, nextFreeChannelId, channelName);
 		return channels[nextFreeChannelId];
