+
+		if (entity == playerEntity)
+		{
+			return true;
+		}
+
+		if (entity is EntityPlayer)
+		{
+			entity = null;
+			return false;
+		}
+
+		if (playerEntity.MountedOn?.MountSupplier?.OnEntity == entity)
+		{
+			return true;
+		}
+
+		double maxRange = player.WorldData.PickingRange + StratumEntityPacketRangeSlack;
+		if (playerEntity.Pos.SquareDistanceTo(entity.Pos) <= maxRange * maxRange)
+		{
+			return true;
+		}
+
+		Logger.Audit("{0} tried to send an entity packet out of range to entity {1}", player.PlayerName, packet.EntityId);
+		entity = null;
+		return false;
+	}
