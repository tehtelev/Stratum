+	private static bool ShouldDropStratumChat(ConnectedClient client, string message)
+	{
+		StratumChatConfig cfg = StratumRuntime.Config.Performance.Chat;
+		if (!cfg.Enabled || string.IsNullOrEmpty(message))
+		{
+			return false;
+		}
+		if (cfg.ExemptCommands && message.Length > 0 && (message[0] == '/' || message[0] == '.'))
+		{
+			return false;
+		}
+		long now = Environment.TickCount64;
+		if (cfg.MinIntervalMs > 0 && client.StratumLastChatMs != 0L && now - client.StratumLastChatMs < cfg.MinIntervalMs)
+		{
+			client.StratumDroppedChatCount++;
+			return true;
+		}
+		if (cfg.DropDuplicates && cfg.DuplicateWindowMs > 0
+			&& client.StratumLastChatMessage != null
+			&& now - client.StratumLastChatMessageMs < cfg.DuplicateWindowMs
+			&& string.Equals(client.StratumLastChatMessage, message, StringComparison.Ordinal))
+		{
+			client.StratumDroppedChatCount++;
+			return true;
+		}
+		client.StratumLastChatMs = now;
+		client.StratumLastChatMessage = message;
+		client.StratumLastChatMessageMs = now;
+		return false;
+	}
