+	private int CleanupStratumChunkColumnRequests(StratumChunkRequestManagementConfig config)
+	{
+		if (!config.Enabled || !config.CancelStalePendingRequests)
+		{
+			stratumTrackedChunkColumnRequests.Clear();
+			return 0;
+		}
+
+		long nowMs = server.ElapsedMilliseconds;
+		if (nowMs < stratumNextChunkRequestCleanupMs)
+		{
+			return 0;
+		}
+
+		stratumNextChunkRequestCleanupMs = nowMs + config.CleanupIntervalMilliseconds;
+		int inspectedRequests = 0;
+		int cancelledRequests = 0;
+		List<long> requestsToForget = null;
+
+		foreach (KeyValuePair<long, StratumTrackedChunkColumnRequest> entry in stratumTrackedChunkColumnRequests)
+		{
+			if (++inspectedRequests > config.MaxTrackedRequestsPerCleanup)
+			{
+				break;
+			}
+
+			long mapChunkIndex = entry.Key;
+			StratumTrackedChunkColumnRequest request = entry.Value;
+			if (!server.ChunkColumnRequested.ContainsKey(mapChunkIndex))
+			{
+				(requestsToForget ??= new List<long>()).Add(mapChunkIndex);
+				continue;
+			}
+
+			if (nowMs - request.RequestedAtMilliseconds < config.MinimumPendingAgeSeconds * 1000L)
+			{
+				continue;
+			}
+
+			if (cancelledRequests >= config.MaxCancelledRequestsPerCleanup || IsStratumChunkColumnStillWanted(request, config))
+			{
+				continue;
+			}
+
+			if (RemovePendingStratumChunkColumnRequest(mapChunkIndex))
+			{
+				cancelledRequests++;
+			}
+
+			(requestsToForget ??= new List<long>()).Add(mapChunkIndex);
+		}
+
+		if (requestsToForget != null)
+		{
+			foreach (long mapChunkIndex in requestsToForget)
+			{
+				stratumTrackedChunkColumnRequests.Remove(mapChunkIndex);
+			}
+		}
+
+		return cancelledRequests;
+	}
+
+	private bool RemovePendingStratumChunkColumnRequest(long mapChunkIndex)
+	{
+		lock (server.requestedChunkColumnsLock)
+		{
+			if (!server.requestedChunkColumns.Contains(mapChunkIndex))
+			{
+				return false;
