+	private int GetStratumChunkDistanceRing(ConnectedClient client, int chunkX, int chunkZ)
+	{
+		int clientChunkX = (int)client.Position.X / MagicNum.ServerChunkSize;
+		int clientChunkZ = (int)client.Position.Z / MagicNum.ServerChunkSize;
+		return Math.Max(Math.Abs(chunkX - clientChunkX), Math.Abs(chunkZ - clientChunkZ));
+	}
