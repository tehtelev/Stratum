+	private List<ConnectedClient> GetStratumChunkBudgetClientOrder(StratumChunkSendingConfig config)
+	{
+		List<ConnectedClient> clients = stratumChunkBudgetClientOrder;
+		clients.Clear();
+		foreach (ConnectedClient client in server.Clients.Values)
+		{
+			clients.Add(client);
+		}
+
+		int count = clients.Count;
+		if (count <= 1)
+		{
+			return clients;
+		}
+
+		int offset = stratumClientBudgetRotation % count;
+		stratumClientBudgetRotation = (stratumClientBudgetRotation + 1) % count;
+		if (offset != 0)
+		{
+			clients.Reverse(0, offset);
+			clients.Reverse(offset, count - offset);
+			clients.Reverse();
+		}
+		if (config.FairSchedulingEnabled)
+		{
+			long nowMs = server.ElapsedMilliseconds;
+			clients.Sort((left, right) =>
+			{
+				StratumClientChunkSendWindow leftWindow = GetStratumChunkSendWindow(left.Id, nowMs, config);
+				StratumClientChunkSendWindow rightWindow = GetStratumChunkSendWindow(right.Id, nowMs, config);
+				int compare = leftWindow.ChunksSent.CompareTo(rightWindow.ChunksSent);
+				if (compare != 0)
+				{
+					return compare;
+				}
+				compare = left.CurrentChunkSentRadius.CompareTo(right.CurrentChunkSentRadius);
+				if (compare != 0)
+				{
+					return compare;
+				}
+				return left.Id.CompareTo(right.Id);
+			});
+		}
+		return clients;
+	}
+
+	private StratumClientChunkSendWindow GetStratumChunkSendWindow(int clientId, long nowMs, StratumChunkSendingConfig config)
+	{
+		if (!stratumClientChunkSendWindows.TryGetValue(clientId, out StratumClientChunkSendWindow window))
+		{
+			window = new StratumClientChunkSendWindow(nowMs);
+			stratumClientChunkSendWindows[clientId] = window;
+			return window;
+		}
+
+		if (nowMs - window.WindowStartedMilliseconds >= config.FairWindowMilliseconds)
+		{
+			window.Reset(nowMs);
+		}
+
+		return window;
 	}
 
