+	private int ApplyStratumOutboundPressureBudget(ConnectedClient client, int budget, StratumChunkSendingConfig config, out bool pressureReduced)
+	{
+		pressureReduced = false;
+		if (budget <= 0 || !config.OutboundPressureEnabled || client.Socket is not TcpNetConnection tcp)
+		{
+			return budget;
+		}
+
+		StratumNetworkFlush.GetBufferedPressure(tcp, out int pendingSends, out long pendingBytes);
+		if (pendingSends < config.OutboundPressurePendingSendsSoftLimit && pendingBytes < config.OutboundPressurePendingBytesSoftLimit)
+		{
+			return budget;
+		}
+
+		float scale = config.OutboundPressureScale;
+		if (pendingSends >= config.OutboundPressurePendingSendsHardLimit || pendingBytes >= config.OutboundPressurePendingBytesHardLimit)
+		{
+			scale *= 0.5f;
+		}
+
+		int reduced = (int)Math.Floor(budget * scale);
+		reduced = Math.Max(config.OutboundPressureMinimumClientBudget, reduced);
+		reduced = Math.Min(budget, reduced);
+		pressureReduced = reduced < budget;
+		return reduced;
+	}
