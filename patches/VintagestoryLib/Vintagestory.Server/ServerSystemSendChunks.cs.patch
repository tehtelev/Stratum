+	private int GetStratumAdaptiveChunkSendBudget(StratumChunkSendingConfig config, bool serverBudget)
+	{
+		int baseBudget = Math.Max(1, serverBudget ? config.MaxChunksPerServerTick : config.MaxChunksPerClientTick);
+		if (!config.AdaptiveUnderOverload || !IsStratumChunkPipelineOverloaded(config.OverloadTickMs))
+		{
+			return baseBudget;
+		}
+
+		int floor = Math.Max(1, serverBudget ? config.OverloadFloorServerTick : config.OverloadFloorClientTick);
+		int scaled = (int)Math.Floor(baseBudget * config.OverloadScale);
+		return Math.Min(baseBudget, Math.Max(floor, scaled));
+	}
+
+	private int GetStratumAdaptiveChunkGenerationBudget(StratumChunkGenerationConfig config, bool serverBudget)
+	{
+		int baseBudget = Math.Max(1, serverBudget ? config.MaxColumnRequestsPerServerTick : config.MaxColumnRequestsPerClientTick);
+		if (!config.AdaptiveUnderOverload || !IsStratumChunkPipelineOverloaded(config.OverloadTickMs))
+		{
+			return baseBudget;
+		}
+
+		int floor = Math.Max(1, serverBudget ? config.OverloadFloorServerTick : config.OverloadFloorClientTick);
+		int scaled = (int)Math.Floor(baseBudget * config.OverloadScale);
+		return Math.Min(baseBudget, Math.Max(floor, scaled));
+	}
+
+	private bool IsStratumChunkPipelineOverloaded(int thresholdMs)
+	{
+		StatsCollection stats = server.StatsCollector[GameMath.Mod(server.StatsCollectorIndex - 1, server.StatsCollector.Length)];
+		return stats != null && stats.ticksTotal > 0 && (double)stats.tickTimeTotal / stats.ticksTotal > thresholdMs;
+	}
