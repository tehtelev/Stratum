+		{
+			return false;
+		}
+
+		blockEntity = server.WorldMap.GetBlockEntity(pos);
+		if (blockEntity == null)
+		{
+			return false;
+		}
+
+		if (!HasOpenInventorySessionForBlockEntityPacket(blockEntity, player, packet.Packetid))
+		{
+			return false;
+		}
+
+		if (!IsBlockEntityPacketInRange(player, pos))
+		{
+			ServerMain.Logger.Audit("{0} tried to send a block entity packet out of range at {1}", player.PlayerName, pos);
+			// Stratum: track this low-noise packet violation for staff alerting.
+			StratumAnticheatReporter.RecordBlockEntityOutOfRange(server, player, pos);
+			return false;
+		}
+
+		BlockSelection blockSelection = new BlockSelection
+		{
+			Position = pos,
+			Face = BlockFacing.UP,
+			HitPosition = new Vec3d(0.5, 0.5, 0.5),
+			SelectionBoxIndex = 0
+		};
+
+		if (server.WorldMap.TestBlockAccess(player, blockSelection, EnumBlockAccessFlags.Use) == EnumWorldAccessResponse.Granted)
+		{
+			return true;
+		}
+
+		if (server.WorldMap.TestBlockAccess(player, blockSelection, EnumBlockAccessFlags.BuildOrBreak) == EnumWorldAccessResponse.Granted)
+		{
+			return true;
+		}
+
+		blockEntity = null;
+		return false;
+	}
+
+	private static bool HasOpenInventorySessionForBlockEntityPacket(BlockEntity blockEntity, ServerPlayer player, int packetId)
+	{
+		if (packetId == (int)EnumBlockEntityPacketId.Open || packetId == (int)EnumBlockEntityPacketId.Close)
+		{
+			return true;
+		}
+
+		if (!(blockEntity is IBlockEntityContainer container))
+		{
+			return true;
+		}
+
+		IInventory inventory;
+		try
+		{
+			inventory = container.Inventory;
+		}
+		catch
+		{
+			return false;
+		}
+
+		return inventory != null && inventory.HasOpened(player);
+	}
+
+	private static bool IsBlockEntityPacketInRange(ServerPlayer player, BlockPos pos)
+	{
+		double maxRange = player.WorldData.PickingRange + StratumBlockEntityPacketRangeSlack;
+		FastVec3d eyes = player.Entity.Pos.XYZFast.Add(player.Entity.LocalEyePos);
+		double dx = eyes.X - (pos.X + 0.5);
+		double dy = eyes.Y - (pos.InternalY + 0.5);
+		double dz = eyes.Z - (pos.Z + 0.5);
+		return dx * dx + dy * dy + dz * dz <= maxRange * maxRange;
+	}
+
+	private bool TryHandleDevCommandBlockUse(Packet_BlockEntityPacket packet, ConnectedClient client)
+	{
+		BlockPos pos = new BlockPos(packet.X, packet.Y, packet.Z);
