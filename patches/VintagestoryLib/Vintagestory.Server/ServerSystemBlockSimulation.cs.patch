+	private static bool IsBlockEntityPacketInRange(ServerPlayer player, BlockPos pos)
+	{
+		double maxRange = player.WorldData.PickingRange + StratumBlockEntityPacketRangeSlack;
+		FastVec3d eyes = player.Entity.Pos.XYZFast.Add(player.Entity.LocalEyePos);
+		double dx = eyes.X - (pos.X + 0.5);
+		double dy = eyes.Y - (pos.InternalY + 0.5);
+		double dz = eyes.Z - (pos.Z + 0.5);
+		return dx * dx + dy * dy + dz * dz <= maxRange * maxRange;
+	}
