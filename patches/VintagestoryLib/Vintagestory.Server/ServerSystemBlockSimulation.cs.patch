+			Type = EnumCallerType.Block,
+			Pos = pos.ToVec3d()
+		};
+		block?.Activate(server, caller, new BlockSelection
+		{
+			Position = pos,
+			Face = BlockFacing.UP,
+			HitPosition = new Vec3d(0.5, 0.5, 0.5),
+			SelectionBoxIndex = 0
+		});
+		return true;
+	}
+
+	private bool TryAllowDevCommandBlockUse(BlockPos pos, ConnectedClient client)
+	{
+		ServerPlayer player = client?.Player;
+		if (player == null || player.Entity == null || !server.WorldMap.IsValidPos(pos) || server.WorldMap.GetChunk(pos) == null)
+		{
+			return false;
+		}
+
+		if (player.HasPrivilege(Privilege.controlserver))
+		{
+			return true;
+		}
+
+		if (!IsBlockEntityPacketInRange(player, pos))
+		{
+			ServerMain.Logger.Audit("{0} tried to trigger a dev command block out of range at {1}", player.PlayerName, pos);
+			return false;
+		}
+
+		BlockSelection blockSelection = new BlockSelection
+		{
+			Position = pos,
+			Face = BlockFacing.UP,
+			HitPosition = new Vec3d(0.5, 0.5, 0.5),
+			SelectionBoxIndex = 0
+		};
+
+		return server.WorldMap.TestBlockAccess(player, blockSelection, EnumBlockAccessFlags.BuildOrBreak) == EnumWorldAccessResponse.Granted;
+	}
+
+	private void FireTickerAdjacent(BlockPos pos)
+	{
+		Caller caller = new Caller
+		{
+			CallerPrivileges = new[] { "*" },
+			Pos = pos.ToVec3d(),
+			Type = EnumCallerType.Block
+		};
+
+		BlockFacing[] facings = { BlockFacing.NORTH, BlockFacing.EAST, BlockFacing.SOUTH, BlockFacing.WEST };
+		for (int i = 0; i < facings.Length; i++)
+		{
+			BlockFacing facing = facings[i];
+			BlockPos sidePos = pos.AddCopy(facing);
+			Block block = server.BlockAccessor.GetBlock(sidePos);
+			block?.Activate(server, caller, new BlockSelection
+			{
+				Position = sidePos,
+				Face = facing.Opposite,
+				HitPosition = new Vec3d(0.5, 0.5, 0.5),
+				SelectionBoxIndex = 0
+			});
+		}
+	}
+
+	private static bool IsDevCommandBlockTarget(BlockEntity be)
+	{
+		Type type = be.GetType();
+		if (TypeIsOrInherits(type, "Vintagestory.GameContent.BlockEntityCommands")) return true;
+		if (TypeIsOrInherits(type, "Vintagestory.GameContent.BlockEntityGuiConfigurableCommands")) return true;
+		if (TypeIsOrInherits(type, "Vintagestory.GameContent.BlockEntityConditional")) return true;
+		if (TypeIsOrInherits(type, "Vintagestory.GameContent.BlockEntityTicker")) return true;
+
+		if (be.Behaviors == null) return false;
+		foreach (BlockEntityBehavior behavior in be.Behaviors)
+		{
+			if (behavior != null && TypeIsOrInherits(behavior.GetType(), "Vintagestory.GameContent.BEBehaviorJonasHydraulicPump")) return true;
+		}
+		return false;
+	}
+
+	private static bool TypeIsOrInherits(Type type, string fullName)
+	{
+		for (Type cur = type; cur != null && cur != typeof(object); cur = cur.BaseType)
+		{
+			if (cur.FullName == fullName) return true;
+		}
+		return false;
 	}
 
