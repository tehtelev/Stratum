+	/// <summary>
+	/// Stratum: Builds a priority list of chunks sorted by proximity to players.
+	/// Uses a top-K heap for O(N log K) instead of a full O(N log N) sort.
+	/// Returns null if prioritization is disabled.
+	/// </summary>
+	private List<ChunkColumnLoadRequest> TryBuildStratumPriorityList()
+	{
+		StratumChunkPriorityConfig prioCfg = StratumRuntime.Config?.Performance?.ChunkPriority;
+		if (prioCfg == null || !prioCfg.Enabled)
+			return null;
+
+		stratumCandidatesBuffer.Clear();
+
+		int qcount = chunkthread.requestedChunkColumns.Count;
+		if (qcount == 0) return stratumCandidatesBuffer;
+
+		IPlayer[] players = server.AllOnlinePlayers;
+		if (players == null || players.Length == 0)
+			return stratumCandidatesBuffer;
+
+		// Compute predicted player positions (accounting for motion vector)
+		float pred = prioCfg.PredictionSeconds * 30f;
+		if (stratumPlayerCx.Length < players.Length)
+		{
+			stratumPlayerCx = new float[players.Length];
+			stratumPlayerCz = new float[players.Length];
+		}
+		int pi = 0;
+		for (int p = 0; p < players.Length; p++)
+		{
+			Entity ent = players[p]?.Entity;
+			if (ent == null)
+				continue;
+			EntityPos pos = ent.SidedPos;
+			if (pos == null)
+				continue;
+			// Position prediction: current + velocity * time
+			double px = pos.X + (pred > 0f ? pos.Motion.X * pred : 0.0);
+			double pz = pos.Z + (pred > 0f ? pos.Motion.Z * pred : 0.0);
+			// Convert to chunk coordinates (1 chunk = 32 blocks)
+			stratumPlayerCx[pi] = (float)(px / 32.0);
+			stratumPlayerCz[pi] = (float)(pz / 32.0);
+			pi++;
+		}
+		if (pi == 0)
+			return stratumCandidatesBuffer;
+		stratumPlayerCount = pi;
+
+		// Stratum: top-K selection via bounded max-heap.
+		// Honestly iterate the entire queue.
+		int cap = Math.Min(qcount, prioCfg.MaxSortedPerTick);
+		stratumTopKHeap.Clear();
+
+		foreach (ChunkColumnLoadRequest r in chunkthread.requestedChunkColumns)
+		{
+			if (r == null || r.Disposed)
+				continue;
+
+			// Compute minimum distance to any player
+			float distSq = StratumMinSqDistToPlayers(r, stratumPlayerCx, stratumPlayerCz, stratumPlayerCount);
+
+			if (stratumTopKHeap.Count < cap)
+			{
+				// Heap not full — add (priority = -distSq: Peek = the farthest)
+				stratumTopKHeap.Enqueue(r, -distSq);
+			}
+			else if (stratumTopKHeap.TryPeek(out _, out float worstNegDist) && distSq < -worstNegDist)
+			{
+				// Closer than the farthest in top-K — replace
+				stratumTopKHeap.Dequeue();
+				stratumTopKHeap.Enqueue(r, -distSq);
+			}
+		}
+
+		// Extract from heap (farthest to nearest) and reverse
+		while (stratumTopKHeap.Count > 0)
+		{
+			stratumCandidatesBuffer.Add(stratumTopKHeap.Dequeue());
+		}
+		stratumCandidatesBuffer.Reverse(); // Now nearest to farthest
+
+		return stratumCandidatesBuffer;
+	}
