+	/// <summary>
+	/// Dispatcher: scans the request queue and sends ready tasks to the worker channel.
+	/// Returns true if at least one task was dispatched.
+	/// </summary>
+	private bool ScheduleReadyTasks()
+	{
+		if (!Monitor.TryEnter(dispatcherLock)) return false;
+		try
+		{
+			if (pauseAllWorldgenThreads > 0) return false;
+			if (dispatcherShuttingDown || server.stopped) return false;
+			if (chunkthread.requestedChunkColumns.Count == 0) return false;
+
+			int dispatched = 0;
+
+			try
+			{
+				foreach (var req in chunkthread.requestedChunkColumns)
+				{
+					if (req == null || req.Disposed) continue;
+
+					// Determine the current incomplete generation stage
+					int stage = req.CurrentIncompletePass_AsInt;
+					if (stage < 1 || stage >= (int)EnumWorldGenPass.Done) continue;
+
+					// Skip if the stage is already occupied by another thread
+					if (stratumStageBusy[stage]) continue;
+
+					// Atomically claim the stage
+					if (Interlocked.CompareExchange(ref stratumStageBusy[stage], true, false) != false)
+						continue;
+
+					// ── Everything that can throw is wrapped in try/finally ──
+					bool handedOff = false;
+					try
+					{
+						// Re-verify: currentpass may have changed between the read and the CAS
+						if (req.CurrentIncompletePass_AsInt != stage)
+							continue; // finally will release
+
+						if (stage >= req.untilPass)
+						{
+							req.FlagToRequeue();
+							continue; // finally will release
+						}
+
+						if (!ensurePrettyNeighbourhood(req))
+							continue; // finally will release
+
+						// Pass the stage TOGETHER with the request
+						readyTasksQueue.Add(new DispatchedTask(req, stage));
+						handedOff = true; // ownership transferred to the worker
+						dispatched++;
+					}
+					finally
+					{
+						if (!handedOff)
+						{
+							stratumStageBusy[stage] = false;
+							// SignalDispatcher();	// The call seems unnecessary
+						}
+					}
+				}
 			}
+			catch (InvalidOperationException) when (!readyTasksQueue.IsAddingCompleted)
+			{
+				// Collection was modified during iteration - normal, will retry next tick
+			}
+			catch (InvalidOperationException)
+			{
+				// Channel completed (CompleteAdding) - exit
+				return false;
+			}
+
+			return dispatched > 0;
+		}
+		catch (Exception ex)
+		{
+			ServerMain.Logger.Error("Dispatcher error: " + ex);
+			return false;
+		}
+		finally
+		{
+			Monitor.Exit(dispatcherLock);
 		}
 	}
 
