+    private ServerMapChunk TryLoadMapChunk(int chunkX, int chunkZ)
+    {
+        byte[] mapChunk = chunkthread.gameDatabase.GetMapChunk(chunkX, chunkZ);
+        if (mapChunk != null)
+        {
+            try
+            {
+                ServerMapChunk serverMapChunk = ServerMapChunk.FromBytes(mapChunk);
