+		// Tiered ticking: pick interval based on distance to nearest player.
+		int tickInterval = GetStratumTierTickInterval(entity, config);
+
+		// Stratum ambient-fauna tier (Paper-style): cosmetic mobs like fish/butterflies/bees don't
+		// need 30Hz AI even when a player is right next to them. Multiplies the distance-band interval.
+		bool stratumIsAmbient = false;
+		if (stratumAmbientTierEnabledCached && entity.IsCreature && stratumAmbientPrefixesCached.Length > 0)
+		{
+			stratumEntityTickStates.TryGetValue(entity.EntityId, out StratumEntityTickState ambientState);
+			if (ambientState == null)
+			{
+				ambientState = new StratumEntityTickState();
+				stratumEntityTickStates[entity.EntityId] = ambientState;
+			}
+			if (!ambientState.AmbientResolved)
+			{
+				string codePath = entity.Code?.Path;
+				if (codePath != null)
+				{
+					string[] prefixes = stratumAmbientPrefixesCached;
