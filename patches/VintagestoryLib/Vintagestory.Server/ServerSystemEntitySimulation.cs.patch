+	private void BuildStratumPlayerPositions()
+	{
+		stratumPlayerPositions.Clear();
+		int snapCount = 0;
+		foreach (ConnectedClient client in server.Clients.Values)
+		{
+			if (client.IsPlayingClient && client.Entityplayer != null)
+			{
+				stratumPlayerPositions.Add(client.Entityplayer.Pos);
+				snapCount++;
+			}
+		}
+		// Mirror into a compact struct array so the per-entity tier-tick loop reads cache-friendly
+		// value data instead of chasing into EntityPos objects (which have ~20 fields each).
+		if (stratumPlayerPosSnap.Length < snapCount)
+		{
+			stratumPlayerPosSnap = new StratumPlayerPosSnap[Math.Max(snapCount, stratumPlayerPosSnap.Length * 2)];
+		}
+		int i = 0;
+		foreach (EntityPos p in stratumPlayerPositions)
+		{
+			stratumPlayerPosSnap[i].X = p.X;
+			stratumPlayerPosSnap[i].Y = p.Y;
+			stratumPlayerPosSnap[i].Z = p.Z;
+			stratumPlayerPosSnap[i].Dimension = p.Dimension;
+			i++;
+		}
+		stratumPlayerPosSnapCount = snapCount;
+
+		// Cache squared distance thresholds & tick intervals once per tick instead of
+		// re-deriving them per entity inside GetStratumTierTickInterval.
+		StratumEntityTickingConfig cfg = StratumRuntime.Config.Performance.EntityTicking;
+		int near = Math.Max(0, cfg.NearDistanceBlocks);
+		int mid = Math.Max(near, cfg.MidDistanceBlocks);
+		int far = Math.Max(mid, cfg.FarEntityDistanceBlocks);
+		stratumNearSqCached = (double)near * near;
+		stratumMidSqCached = (double)mid * mid;
+		stratumFarSqCached = (double)far * far;
+		stratumMidTickIntervalCached = Math.Max(1, cfg.MidTickInterval);
+		stratumFarTickIntervalCached = Math.Max(1, cfg.FarEntityTickInterval);
+		stratumVeryFarTickIntervalCached = Math.Max(1, cfg.VeryFarTickInterval);
+
+		stratumAmbientTierEnabledCached = cfg.AmbientFaunaTierEnabled;
+		stratumAmbientMultiplierCached = Math.Max(1, cfg.AmbientFaunaTickMultiplier);
+		List<string> prefixSrc = cfg.AmbientFaunaCodePrefixes;
+		if (prefixSrc == null || prefixSrc.Count == 0)
+		{
+			stratumAmbientPrefixesCached = Array.Empty<string>();
+		}
+		else if (stratumAmbientPrefixesCached.Length != prefixSrc.Count)
+		{
+			stratumAmbientPrefixesCached = prefixSrc.ToArray();
+		}
+
+		stratumHardDespawnEnabledCached = cfg.HardDespawnEnabled;
+		int hardDist = Math.Max(32, cfg.HardDespawnDistanceBlocks);
+		stratumHardDespawnSqCached = (double)hardDist * hardDist;
+		stratumHardDespawnGraceSecondsCached = Math.Max(1, cfg.HardDespawnGracePeriodSeconds);
+		stratumHardDespawnExemptIfNamedCached = cfg.HardDespawnExemptIfNamed;
+		List<string> exemptSrc = cfg.HardDespawnExemptCodePrefixes;
+		if (exemptSrc == null || exemptSrc.Count == 0)
+		{
+			stratumHardDespawnExemptPrefixesCached = Array.Empty<string>();
+		}
+		else if (stratumHardDespawnExemptPrefixesCached.Length != exemptSrc.Count)
+		{
+			stratumHardDespawnExemptPrefixesCached = exemptSrc.ToArray();
+		}
+	}
+
+	// Returns true if the entity was marked for hard despawn this tick. Caller should add the
+	// entity to the per-tick despawn list and skip ticking. Safe to call from worker threads in
+	// the region-parallel path because each entity is owned by exactly one region bucket and the
+	// only mutated state is its own StratumEntityTickState entry plus its own ShouldDespawn/
+	// DespawnReason fields.
+	private bool EvaluateStratumHardDespawn(Entity entity, float dt, out EntityDespawnData reason)
+	{
+		reason = default;
+		if (!stratumHardDespawnEnabledCached) return false;
+		if (entity is EntityPlayer) return false;
+		if (!entity.IsCreature) return false;
+		if (entity.ShouldDespawn) return false;
+		if (stratumPlayerPosSnapCount == 0) return false; // no players online ╬ô├ç├╢ leave entities alone
+
+		string codePath = entity.Code?.Path;
+		if (codePath != null)
+		{
+			string[] prefixes = stratumHardDespawnExemptPrefixesCached;
+			for (int i = 0; i < prefixes.Length; i++)
+			{
+				if (codePath.StartsWith(prefixes[i], StringComparison.Ordinal)) return false;
+			}
+		}
+
+		if (stratumHardDespawnExemptIfNamedCached)
+		{
+			string named = entity.WatchedAttributes?.GetTreeAttribute("nametag")?.GetString("name");
+			if (!string.IsNullOrEmpty(named)) return false;
+		}
+
+		double ex = entity.Pos.X, ey = entity.Pos.Y, ez = entity.Pos.Z;
+		int ed = entity.Pos.Dimension;
+		double bestSq = double.MaxValue;
+		for (int i = 0; i < stratumPlayerPosSnapCount; i++)
+		{
+			ref StratumPlayerPosSnap p = ref stratumPlayerPosSnap[i];
+			if (p.Dimension != ed) continue;
+			double dx = p.X - ex, dy = p.Y - ey, dz = p.Z - ez;
+			double sq = dx * dx + dy * dy + dz * dz;
+			if (sq < bestSq) bestSq = sq;
+		}
+
+		if (bestSq <= stratumHardDespawnSqCached)
+		{
+			if (stratumEntityTickStates.TryGetValue(entity.EntityId, out StratumEntityTickState st0) && st0.FarSecondsAccumulated != 0f)
+			{
+				st0.FarSecondsAccumulated = 0f;
+			}
+			return false;
+		}
+
+		if (!stratumEntityTickStates.TryGetValue(entity.EntityId, out StratumEntityTickState st))
+		{
+			st = new StratumEntityTickState();
+			stratumEntityTickStates[entity.EntityId] = st;
+		}
+		st.FarSecondsAccumulated += dt;
+		if (st.FarSecondsAccumulated < stratumHardDespawnGraceSecondsCached) return false;
+
+		reason = new EntityDespawnData { Reason = EnumDespawnReason.Unload };
+		entity.DespawnReason = reason;
+		return true;
+	}
