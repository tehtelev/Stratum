+	private bool ShouldDelayStratumAutoSave()
+	{
+		StratumAutoSaveConfig autoSave = StratumRuntime.Config.Performance.AutoSave;
+		if (!autoSave.Enabled || !autoSave.DelayDuringChunkPressure)
+		{
+			stratumAutoSaveFirstDueMs = -1;
+			return false;
+		}
+
+		if (stratumAutoSaveFirstDueMs < 0)
+		{
+			stratumAutoSaveFirstDueMs = millisecondsSinceStart;
+		}
+
+		int pendingColumnRequests = GetPendingChunkColumnQueueCount();
+		int workerColumnRequests = server.chunkThread?.requestedChunkColumns.Count ?? 0;
+		bool chunkPressure = pendingColumnRequests > Math.Max(0, autoSave.MaxPendingChunkColumns) || workerColumnRequests > Math.Max(0, autoSave.MaxWorkerChunkColumns);
+		int delaySeconds = GetStratumAutoSaveDelaySeconds();
+		if (!chunkPressure || delaySeconds >= Math.Max(0, autoSave.MaxDelaySeconds))
+		{
+			return false;
+		}
+
+		StratumRuntime.PerformanceStats.RecordAutoSaveDelayed(pendingColumnRequests, workerColumnRequests, delaySeconds);
+		return true;
+	}
+
+	private int GetStratumAutoSaveDelaySeconds()
