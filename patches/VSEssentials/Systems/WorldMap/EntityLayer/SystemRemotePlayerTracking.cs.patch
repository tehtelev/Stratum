+        private static PacketPlayerPosition MaybeSnap(PacketPlayerPosition packet, IServerPlayer sender, IServerPlayer receiver)
+        {
+            int? snap = PlayerMapDisclosureHook.CoordinateSnap?.Invoke(sender, receiver);
+            if (snap == null || snap.Value <= 0) return packet;
+
+            int grid = snap.Value;
+            return new PacketPlayerPosition
+            {
+                PlayerUid = packet.PlayerUid,
+                PlayerName = packet.PlayerName,
+                PosX = System.Math.Floor(packet.PosX / grid) * grid + grid / 2.0,
+                PosZ = System.Math.Floor(packet.PosZ / grid) * grid + grid / 2.0,
+                Yaw = packet.Yaw,
+                Despawn = packet.Despawn
+            };
+        }
