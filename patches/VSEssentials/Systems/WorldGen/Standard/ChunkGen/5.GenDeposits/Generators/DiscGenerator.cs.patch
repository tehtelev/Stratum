+        /// <summary>
+        /// Fast hash function returning 0-1
+        /// </summary>
+        /// <param name="x"></param>
+        /// <param name="z"></param>
+        /// <returns></returns>
+        float FastNoise(int x, int z)
+        {
+            uint hash = (uint)(x * 1619 + z * 31337);
+            hash = (hash ^ 61) ^ (hash >> 16);
+            hash *= 9;
+            hash ^= hash >> 4;
+            hash *= 0x27d4eb2d;
+            hash ^= hash >> 15;
+            return hash * invUintMax;
+        }
+
+        // Stratum end
