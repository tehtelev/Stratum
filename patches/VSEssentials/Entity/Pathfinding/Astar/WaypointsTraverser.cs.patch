+        private bool StratumPrepareAsyncSearch(BlockPos targetBlockPos, float modeMinFleeDistance)
+        {
+            long nowMs = entity.World.ElapsedMilliseconds;
+            if (stratumPathCooldownUntilMs > nowMs)
+            {
+                return false;
+            }
+
+            if (asyncSearchObject == null)
+            {
+                return true;
+            }
+
+            if (!asyncSearchObject.Finished && StratumSameAsyncGoal(targetBlockPos, modeMinFleeDistance))
+            {
+                return false;
+            }
+
+            StratumCancelAsyncSearch();
+            return true;
+        }
+
+        private bool StratumSameAsyncGoal(BlockPos targetBlockPos, float modeMinFleeDistance)
+        {
+            return stratumAsyncTargetBlockPos != null
+                && stratumAsyncTargetBlockPos.X == targetBlockPos.X
+                && stratumAsyncTargetBlockPos.Y == targetBlockPos.Y
+                && stratumAsyncTargetBlockPos.Z == targetBlockPos.Z
+                && Math.Abs(stratumAsyncModeMinFleeDistance - modeMinFleeDistance) < 0.001f;
+        }
+
+        private void StratumCancelAsyncSearch()
+        {
+            if (asyncSearchObject != null)
+            {
+                asyncSearchObject.waypoints = null;
+                asyncSearchObject.Finished = true;
+                asyncSearchObject = null;
+            }
+
+            stratumAsyncTargetBlockPos = null;
+        }
+
+        private void StratumRecordPathFailure()
+        {
+            stratumConsecutivePathFailures++;
+            if (stratumFailureCooldownAfterFailures > 0 && stratumConsecutivePathFailures >= stratumFailureCooldownAfterFailures)
+            {
+                stratumPathCooldownUntilMs = entity.World.ElapsedMilliseconds + stratumFailureCooldownMs;
+                stratumConsecutivePathFailures = 0;
+            }
+        }
+
+        private void StratumResetPathFailures()
+        {
+            stratumConsecutivePathFailures = 0;
+            stratumPathCooldownUntilMs = 0;
+        }
+
+        private void StratumReadPathfindingConfig()
+        {
+            try
+            {
+                foreach (var assembly in AppDomain.CurrentDomain.GetAssemblies())
+                {
+                    if (assembly.GetName().Name != "VintagestoryLib")
+                    {
+                        continue;
+                    }
+
+                    Type runtimeT = assembly.GetType("Vintagestory.Server.StratumRuntime");
+                    object cfg = runtimeT?.GetProperty("Config", System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Static)?.GetValue(null);
+                    object perf = cfg?.GetType().GetProperty("Performance")?.GetValue(cfg);
+                    object pf = perf?.GetType().GetProperty("Pathfinding")?.GetValue(perf);
+                    if (pf == null)
+                    {
+                        return;
+                    }
+
+                    stratumFailureCooldownAfterFailures = Math.Max(0, (int)(pf.GetType().GetProperty("FailureCooldownAfterFailures")?.GetValue(pf) ?? stratumFailureCooldownAfterFailures));
+                    stratumFailureCooldownMs = Math.Max(0, (int)(pf.GetType().GetProperty("FailureCooldownMs")?.GetValue(pf) ?? stratumFailureCooldownMs));
+                    return;
+                }
+            }
+            catch
+            {
+                // Keep defaults if the Stratum config is not available.
+            }
+        }
+
 
