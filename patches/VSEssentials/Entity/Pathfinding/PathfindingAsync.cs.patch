+        private void StartStratumExtraWorkers()
+        {
+            // Read Stratum config reflectively (lives in VintagestoryLib, internal) to avoid a hard dependency.
+            int extra = 0;
+            int maxQueued = 0;
+            bool asyncEnabled = true;
+            try
+            {
+                Assembly libAsm = AppDomain.CurrentDomain.GetAssemblies()
+                    .FirstOrDefault(a => a.GetName().Name == "VintagestoryLib");
+                Type runtimeT = libAsm?.GetType("Vintagestory.Server.StratumRuntime");
+                object cfg = runtimeT?.GetProperty("Config", BindingFlags.Public | BindingFlags.NonPublic | BindingFlags.Static)?.GetValue(null);
+                object perf = cfg?.GetType().GetProperty("Performance")?.GetValue(cfg);
+                object pf = perf?.GetType().GetProperty("Pathfinding")?.GetValue(perf);
+                if (pf != null)
+                {
+                    asyncEnabled = (bool)(pf.GetType().GetProperty("Async")?.GetValue(pf) ?? true);
+                    int workers = (int)(pf.GetType().GetProperty("WorkerThreads")?.GetValue(pf) ?? 0);
+                    if (workers <= 0) workers = Math.Max(2, Environment.ProcessorCount / 2);
+                    // We already have one built-in worker thread; add (workers - 1) extras.
+                    extra = Math.Max(0, workers - 1);
+                    maxQueued = (int)(pf.GetType().GetProperty("MaxQueued")?.GetValue(pf) ?? 0);
+                }
+            }
+            catch (Exception e)
+            {
+                api.Logger.Warning("Stratum pathfinding config read failed, using defaults: {0}", e.Message);
+            }
+
+            stratumMaxQueued = maxQueued;
+            if (!asyncEnabled || extra <= 0) return;
+
+            for (int i = 0; i < extra; i++)
+            {
+                var worker = new PathfindingAsyncWorker(this, api);
+                stratumExtraWorkers.Add(worker);
+                api.Server.AddServerThread("ai-pathfinding-" + (i + 2), worker);
+            }
+            api.Logger.Notification("Stratum: pathfinding running on {0} parallel worker threads.", 1 + extra);
         }
 
 
