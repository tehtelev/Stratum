+        private void StratumPrunePathfinderQueue(bool forceOneFreeSlot)
+        {
+            if (stratumMaxQueued <= 0)
+            {
+                return;
+            }
+
+            lock (stratumQueueTrimLock)
+            {
+                int count = PathfinderTasks.Count;
+                if (count <= 0)
+                {
+                    return;
+                }
+
+                int targetKeep = stratumMaxQueued > 0 ? (forceOneFreeSlot ? Math.Max(0, stratumMaxQueued - 1) : stratumMaxQueued) : count;
+                bool underPressure = StratumIsQueueUnderPressure(count);
+                List<PathfinderTask> keep = new List<PathfinderTask>(stratumMaxQueued > 0 ? Math.Min(count, stratumMaxQueued) : count);
+                for (int i = 0; i < count && PathfinderTasks.TryDequeue(out PathfinderTask queued); i++)
+                {
+                    if (StratumIsObsoleteTask(queued, out _))
+                    {
+                        StratumMarkDropped(queued);
+                        stratumDroppedStaleTasks++;
+                        continue;
+                    }
+
+                    if (underPressure && StratumShouldDropFarTask(queued))
+                    {
+                        StratumMarkDropped(queued);
+                        stratumDroppedFarTasks++;
+                        continue;
+                    }
+
+                    StratumScoreTask(queued);
+                    keep.Add(queued);
+                }
+
+                if (stratumPriorityEnabled && underPressure)
+                {
+                    keep.Sort(StratumCompareTasks);
+                }
+
+                int overflow = Math.Max(0, keep.Count - targetKeep);
+                for (int i = keep.Count - 1; i >= 0 && overflow > 0; i--, overflow--)
+                {
+                    StratumMarkDropped(keep[i]);
+                    stratumDroppedQueuedTasks++;
+                    keep.RemoveAt(i);
+                }
+
+                for (int i = 0; i < keep.Count; i++)
+                {
+                    PathfinderTasks.Enqueue(keep[i]);
+                }
+            }
+        }
+
+        private bool StratumIsQueueUnderPressure(int queueDepth)
+        {
+            if (!stratumPriorityEnabled)
+            {
+                return false;
+            }
+
+            int threshold = stratumPriorityQueueThreshold;
+            if (threshold <= 0 && stratumMaxQueued > 0)
+            {
+                threshold = Math.Max(1, stratumMaxQueued / 2);
+            }
+
+            return threshold > 0 && queueDepth >= threshold;
+        }
+
+        private bool StratumShouldDropFarTask(PathfinderTask task)
+        {
+            if (!stratumDropFarTasksUnderPressure || stratumFarTaskDistanceBlocks <= 0 || task == null)
+            {
+                return false;
+            }
+
+            double maxDistanceSq = (double)stratumFarTaskDistanceBlocks * stratumFarTaskDistanceBlocks;
+            return task.StratumDropWhenFarUnderPressure && task.StratumNearestPlayerDistanceSq > maxDistanceSq;
+        }
+
+        private void StratumScoreTask(PathfinderTask task)
+        {
+            if (task == null)
+            {
+                return;
+            }
+
+            Vec3d taskPos = null;
+            if (task.SourceEntityId > 0)
+            {
+                Entity owner = api?.World?.GetEntityById(task.SourceEntityId);
+                if (owner != null)
+                {
+                    taskPos = owner.ServerPos?.XYZ ?? owner.Pos?.XYZ;
+                }
+            }
+
+            taskPos ??= new Vec3d(task.startBlockPos.X + 0.5, task.startBlockPos.Y + 0.5, task.startBlockPos.Z + 0.5);
+            double nearestSq = double.MaxValue;
+            IPlayer[] players = api?.World?.AllOnlinePlayers;
+            if (players != null)
+            {
+                for (int i = 0; i < players.Length; i++)
+                {
+                    Entity playerEntity = players[i]?.Entity;
+                    if (playerEntity == null)
+                    {
+                        continue;
+                    }
+
+                    double distanceSq = playerEntity.ServerPos.SquareDistanceTo(taskPos);
+                    if (distanceSq < nearestSq)
+                    {
+                        nearestSq = distanceSq;
+                    }
+                }
+            }
+
+            task.StratumNearestPlayerDistanceSq = nearestSq;
+            task.StratumDropWhenFarUnderPressure = nearestSq < double.MaxValue;
+        }
+
+        private static int StratumCompareTasks(PathfinderTask left, PathfinderTask right)
+        {
+            int distance = left.StratumNearestPlayerDistanceSq.CompareTo(right.StratumNearestPlayerDistanceSq);
+            if (distance != 0)
+            {
+                return distance;
+            }
+
+            return left.EnqueuedMilliseconds.CompareTo(right.EnqueuedMilliseconds);
+        }
+
+        private bool StratumIsObsoleteTask(PathfinderTask task, out string reason)
+        {
+            reason = null;
+            if (task == null || task.Finished)
+            {
+                reason = "finished";
+                return true;
+            }
+
+            long nowMs = api?.World?.ElapsedMilliseconds ?? 0;
+            if (stratumMaxTaskAgeMs > 0 && task.EnqueuedMilliseconds > 0 && nowMs - task.EnqueuedMilliseconds > stratumMaxTaskAgeMs)
+            {
+                reason = "stale";
+                return true;
+            }
+
+            if (task.SourceEntityId > 0)
+            {
+                Entity owner = api?.World?.GetEntityById(task.SourceEntityId);
+                if (owner == null || !owner.Alive || owner.State == EnumEntityState.Inactive || owner.ShouldDespawn)
+                {
+                    reason = "owner-gone";
+                    return true;
+                }
+            }
+
+            return false;
+        }
+
+        private static void StratumMarkDropped(PathfinderTask task)
+        {
+            if (task == null)
+            {
+                return;
+            }
+
+            task.waypoints = null;
+            task.Finished = true;
+        }
