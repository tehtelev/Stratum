+        private bool IsEditableTeleporter(IServerPlayer player, BlockPos sourcePos)
+        {
+            if (player == null || player.Entity == null || sourcePos == null)
+            {
+                return false;
+            }
+
+            if (player.WorldData.CurrentGameMode != EnumGameMode.Creative)
+            {
+                return false;
+            }
+
+            bool canManageServer = player.HasPrivilege(Privilege.controlserver);
+            if (!canManageServer && !player.HasPrivilege(Privilege.buildblocks) && !player.HasPrivilege(Privilege.buildblockseverywhere))
+            {
+                return false;
+            }
+
+            BlockEntityTeleporter be = sapi.World.BlockAccessor.GetBlockEntity(sourcePos) as BlockEntityTeleporter;
+            if (be == null || !(sapi.World.BlockAccessor.GetBlock(sourcePos) is BlockTeleporter))
+            {
+                return false;
+            }
+
+            if (!canManageServer && !sapi.World.Claims.TryAccess(player, sourcePos, EnumBlockAccessFlags.BuildOrBreak))
+            {
+                return false;
+            }
+
+            double dx = player.Entity.Pos.X - (sourcePos.X + 0.5);
+            double dy = player.Entity.Pos.Y - (sourcePos.InternalY + 0.5);
+            double dz = player.Entity.Pos.Z - (sourcePos.Z + 0.5);
+            return dx * dx + dy * dy + dz * dz <= StratumMaxTeleporterConfigDistanceSq;
+        }
+
+        private static string SanitizeTeleporterName(string name, string fallback)
+        {
+            string cleanName = name?.Trim();
+            if (string.IsNullOrEmpty(cleanName))
+            {
+                return string.IsNullOrEmpty(fallback) ? "Location" : fallback;
+            }
+
+            if (cleanName.Length > StratumMaxTeleporterNameLength)
+            {
+                cleanName = cleanName.Substring(0, StratumMaxTeleporterNameLength);
+            }
+
+            return cleanName;
+        }
