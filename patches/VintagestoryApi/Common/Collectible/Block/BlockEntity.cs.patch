+        // Stratum: when > 0, BE tick listeners registered with initialDelayOffsetMs=0 are spread
+        // by Pos.GetHashCode() % min(this, millisecondInterval) so that BEs registered together
+        // (e.g. on chunk load) don't all fire on the same future tick. Set by VintagestoryLib at
+        // server startup from StratumConfig.Performance.BlockEntityInit.
+        public static int StratumDefaultInitialDelaySpreadMs = 0;
+
+        private static int StratumComputeInitialDelay(BlockPos pos, int millisecondInterval)
+        {
+            int spread = StratumDefaultInitialDelaySpreadMs;
+            if (spread <= 0 || millisecondInterval <= 1 || pos == null) return 0;
+            int window = spread < millisecondInterval ? spread : millisecondInterval;
+            return (int)((uint)pos.GetHashCode() % (uint)window);
+        }
